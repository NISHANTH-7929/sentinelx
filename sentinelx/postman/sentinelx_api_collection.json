{
  "info": {
    "name": "SentinelX API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Core API set for incident ingestion, simulator control, moderation, and user registration."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8088"
    },
    {
      "key": "incidentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Create Incident",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source\": \"manual\",\n  \"type\": \"fire\",\n  \"description\": \"Fire reported near central station\",\n  \"latitude\": 13.0827,\n  \"longitude\": 80.2707,\n  \"media_urls\": [\"https://picsum.photos/300/200\"]\n}"
        },
        "url": "{{baseUrl}}/api/incidents"
      }
    },
    {
      "name": "Fetch Incidents",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/incidents?bbox=80.10,12.90,80.40,13.20&since=2024-01-01T00:00:00.000Z&type=fire&status=verified"
      }
    },
    {
      "name": "Start Simulator",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dataset\": \"chennai_crimes.json\",\n  \"replay_speed\": 5,\n  \"loop\": true\n}"
        },
        "url": "{{baseUrl}}/api/simulate/start"
      }
    },
    {
      "name": "Stop Simulator",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{baseUrl}}/api/simulate/stop"
      }
    },
    {
      "name": "Get Pending Incidents",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/admin/incidents/pending"
      }
    },
    {
      "name": "Approve Incident",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{baseUrl}}/admin/incidents/{{incidentId}}/approve"
      }
    },
    {
      "name": "Reject Incident",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{baseUrl}}/admin/incidents/{{incidentId}}/reject"
      }
    },
    {
      "name": "Register User Device",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"demo-user-1\",\n  \"name\": \"Hackathon User\",\n  \"fcm_token\": \"\",\n  \"phone_number\": \"+911234567890\",\n  \"sms_opt_in\": true,\n  \"latitude\": 13.0827,\n  \"longitude\": 80.2707\n}"
        },
        "url": "{{baseUrl}}/api/users/register"
      }
    }
  ]
}
